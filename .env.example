# Copy this file to .env and fill in the values before running deploy.py
# (or export them directly in your shell). Never commit the real .env file.

# Target server
MONITOR_DEPLOY_HOST=192.168.15.101
MONITOR_DEPLOY_PORT=22
MONITOR_DEPLOY_USER=gabe

# SSH password. Leave unset to be prompted securely (getpass) instead.
MONITOR_DEPLOY_PASS=

# Remote install directory. Defaults to /home/<MONITOR_DEPLOY_USER>/server-monitor
# (no sudo required). Uncomment to override, e.g. to install under /opt instead.
# MONITOR_DEPLOY_REMOTE_DIR=/home/gabe/server-monitor
